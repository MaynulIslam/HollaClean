# HollaClean Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Stripe Webhook Secret (for production)
# Get this from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Your domain (without https://)
VITE_APP_DOMAIN=hollaclean.com

# Application URL (with https://)
VITE_APP_URL=https://hollaclean.com

# API Base URL (if using separate backend)
VITE_API_URL=https://api.hollaclean.com

# ============================================
# COMMISSION & FEES
# ============================================
# Platform commission rate (0.20 = 20%)
VITE_COMMISSION_RATE=0.20

# Stripe fee rate (0.029 = 2.9%)
VITE_STRIPE_FEE_RATE=0.029

# Stripe fixed fee per transaction
VITE_STRIPE_FEE_FIXED=0.30

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# SendGrid API Key (for email notifications)
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE

# Email "from" address
EMAIL_FROM=noreply@hollaclean.com
EMAIL_FROM_NAME=HollaClean

# ============================================
# SMS CONFIGURATION (Optional)
# ============================================
# Twilio credentials (for SMS notifications)
# Get from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=AC_YOUR_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Admin dashboard password (change this!)
ADMIN_PASSWORD=change_this_secure_password_123

# Admin email for notifications
ADMIN_EMAIL=admin@hollaclean.com

# ============================================
# GOOGLE SERVICES (Optional)
# ============================================
# Google Maps API Key (for address autocomplete)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Google Analytics (Optional)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# ============================================
# SECURITY
# ============================================
# Session secret (generate a random string)
SESSION_SECRET=generate_a_long_random_string_here

# JWT Secret (for authentication tokens)
JWT_SECRET=another_long_random_string_for_jwt

# ============================================
# ENVIRONMENT
# ============================================
# development, staging, or production
NODE_ENV=production

# ============================================
# NOTES
# ============================================
# - Never commit your .env file to git
# - Keep your secret keys secure
# - Use different keys for development and production
# - Rotate keys periodically for security
